# ------------------------------------------------------------------
# Salesforce Data Explorer — environment variables
# Copy to .env.local for local dev. In production these are set in Vercel.
# ------------------------------------------------------------------

# --- App URL (used to build the OAuth redirect_uri) ---
# Local: http://localhost:3000  |  Prod: https://your-app.vercel.app
APP_BASE_URL=http://localhost:3000

# --- App-level auth gate (single-user) ---
# The password you type to unlock the app.
APP_PASSWORD=change-me-to-a-long-random-string
# Secret used to sign the app session cookie (32+ random chars).
APP_SESSION_SECRET=change-me-to-a-long-random-string

# --- Encryption key for Salesforce refresh tokens at rest ---
# MUST be 32 bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIALS_ENCRYPTION_KEY=

# --- Salesforce Connected App (OAuth 2.0) ---
# NOTE: As of v0.3.0 the Connected App credentials (login URL, consumer key,
# consumer secret) are registered IN-APP on the Connections page and stored
# encrypted in the database — they are no longer environment variables. This
# lets you save multiple Connected Apps / orgs. No SALESFORCE_* vars needed.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Service role key — server-side only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=
